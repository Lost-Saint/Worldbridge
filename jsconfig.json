{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "strict": true,
    "types": ["chrome", "firefox-webext-browser"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./src/**/*"],
  "exclude": ["node_modules", "dist", "src/lib/polyfill.js"]
}
